# Quick Render template (copy-paste): ../../render.env | Full index: ../../ENVAPI
#
# Embedded SQLite (default — no separate database server). Omit DATABASE_URL to use apps/api/data/hub.db automatically.
# DATABASE_URL="file:./data/hub.db"
# Optional: single-site hub — business data in Google Sheet only; JWT from Sheet login (no email/password, no seed-owner).
# HUB_SHEET_ONLY=true

JWT_SECRET=change-me
PORT=4000
# Optional: full origin of this API (no trailing slash). Used for absolute receipt links written to Google Sheets (e.g. https://api.yourdomain.com).
# PUBLIC_API_BASE_URL=http://localhost:4000
# Disable all local invoice/receipt file writes. Requires R2_* + STORAGE_PUBLIC_BASE_URL.
STRICT_NO_LOCAL_STORAGE=true

# Cloudflare R2 (S3-compatible). When all are set, invoice PDFs and expense receipts go to R2 instead of local disk.
# STORAGE_PUBLIC_BASE_URL=https://files.yourdomain.com
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# Optional: folder of .ics files or a single .ics path for Calendar → Workers feed (defaults to Desktop/JR Workers ACCES)
# WORKERS_CALENDAR_PATH=C:\Users\You\Desktop\JR Workers ACCES

# Local disk only (ignored when R2 is configured): invoice PDFs default to repo-root Invoices/
# INVOICES_STORAGE_DIR=C:\absolute\path\to\Invoices
# INVOICE_LOGO_PATH=C:\path\to\photo-jersey-raw-logo.jpg
# INVOICE_SQUARE_CHECKOUT_URL=https://checkout.square.site/merchant/...
# INVOICE_CREDIT_CARD_FEE_RATE=0.033
# INVOICE_ZELLE_EMAIL=JerseyRawHelp@gmail.com
# INVOICE_VENMO_HANDLE=@Christopher-G1

# Run full pending+archive sync + regenerate ALL PDFs on every API start (default: one-time only via stamp file)
# INVOICE_FORCE_FULL_SYNC_ON_START=true

# Secret for POST /integration/final/submit-order (Final consumer site). Send header: X-Final-Order-Secret
# FINAL_ORDER_SUBMIT_SECRET=replace-with-long-random-string

# Google Apps Script single-sheet controller (operations + promo/kickback on-sheet)
GOOGLE_SHEET_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxLRKR-Wqn7FPtRXqvym_txkuyBbqTu0B1dhgePHzFTYt0O8jlrhroX8g154SLLWWDo/exec
# In the Apps Script project (not here): Project Settings > Script properties > JR_SPREADSHEET_ID = your Google Sheet id from the sheet URL (required for Web App GET/pull when active spreadsheet is unavailable).
# Optional dedicated login Web App URL (action=login + sessionPing). Falls back to GOOGLE_SHEET_APPS_SCRIPT_URL when unset.
GOOGLE_SHEET_LOGIN_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxLRKR-Wqn7FPtRXqvym_txkuyBbqTu0B1dhgePHzFTYt0O8jlrhroX8g154SLLWWDo/exec
GOOGLE_SHEET_API_KEY=replace-with-Script-Properties-API_KEY
# GOOGLE_SHEET_SITE_KEY=optional-per-site-key-from-Config-tab-SITE_KEY
# When the hub uses Apps Script login: browser calls POST /auth/sheet-session; API verifies session via ?action=sessionPing
# If HUB_SHEET_ONLY=true: JWT is issued without a User row — set display identity below.
# If HUB_SHEET_ONLY is unset: user for issued JWT — omit to use the first user in the database (e.g. after POST /auth/seed-owner).
# SHEET_HUB_JWT_EMAIL=owner@yourdomain.com
# SHEET_HUB_JWT_SUB=hub-sheet-owner
# SHEET_HUB_JWT_ROLE=OWNER

