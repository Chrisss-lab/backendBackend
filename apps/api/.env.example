# PostgreSQL (local: docker compose up -d, then use URL below)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hub?schema=public"

JWT_SECRET=change-me
PORT=4000

# Cloudflare R2 (S3-compatible). When all are set, invoice PDFs and expense receipts go to R2 instead of local disk.
# STORAGE_PUBLIC_BASE_URL=https://files.yourdomain.com
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# Optional: folder of .ics files or a single .ics path for Calendar → Workers feed (defaults to Desktop/JR Workers ACCES)
# WORKERS_CALENDAR_PATH=C:\Users\You\Desktop\JR Workers ACCES

# Local disk only (ignored when R2 is configured): invoice PDFs default to repo-root Invoices/
# INVOICES_STORAGE_DIR=C:\absolute\path\to\Invoices
# INVOICE_LOGO_PATH=C:\path\to\photo-jersey-raw-logo.jpg
# INVOICE_SQUARE_CHECKOUT_URL=https://checkout.square.site/merchant/...
# INVOICE_CREDIT_CARD_FEE_RATE=0.033
# INVOICE_ZELLE_EMAIL=JerseyRawHelp@gmail.com
# INVOICE_VENMO_HANDLE=@Christopher-G1

# Run full pending+archive sync + regenerate ALL PDFs on every API start (default: one-time only via stamp file)
# INVOICE_FORCE_FULL_SYNC_ON_START=true
