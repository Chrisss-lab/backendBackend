# Full organized index: ../../ENVAPI (repo root)
#
# Leave empty for same-origin (one server on PORT, e.g. http://localhost:4000 — UI + API).
# Set to your API URL only for split dev (next dev on :3001) or Cloudflare Pages + remote API.
NEXT_PUBLIC_API_URL=

# Optional: same Google Calendar Apps Script /exec URL as JR Workers ACCES (src/api/calendar.js).
# When set, Calendar → JR Workers loads/edits live Google Calendar instead of read-only .ics files.
# NEXT_PUBLIC_JR_WORKERS_CALENDAR_APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec

# Optional: public /exec URL for browser→Google calls (sessionPing in SessionGuard). Not required for Sign in
# (that goes API → Apps Script). Must match apps/api GOOGLE_SHEET_APPS_SCRIPT_URL if you set it.
NEXT_PUBLIC_JR_SHEET_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxLRKR-Wqn7FPtRXqvym_txkuyBbqTu0B1dhgePHzFTYt0O8jlrhroX8g154SLLWWDo/exec

# Set to 0/false/no/off to use Nest email/password on /auth/login only (no WebLogin sheet).
# NEXT_PUBLIC_SHEET_WEB_LOGIN=0

# Hub shows /login first (no access until signed in). Set to 1/true only for local dev without auth.
# NEXT_PUBLIC_SKIP_HUB_LOGIN=1

