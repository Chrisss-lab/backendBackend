NEXT_PUBLIC_API_URL=http://localhost:4000
# Cloudflare Pages production: set to your Render API origin, e.g. https://hub-api.onrender.com

# Optional: same Google Calendar Apps Script /exec URL as JR Workers ACCES (src/api/calendar.js).
# When set, Calendar → JR Workers loads/edits live Google Calendar instead of read-only .ics files.
# NEXT_PUBLIC_JR_WORKERS_CALENDAR_APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
